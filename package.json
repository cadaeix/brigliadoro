{
  "name": "brigliadoro",
  "version": "0.1.0",
  "description": "TTRPG harness that generates bespoke game runners using Claude agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run tests/",
    "test:watch": "vitest tests/",
    "test:runners": "vitest run runners/",
    "test:all": "vitest run",
    "test:auditor": "vitest run -c vitest.auditor.config.ts",
    "test:auditor:watch": "vitest -c vitest.auditor.config.ts",
    "generate": "tsx src/meta/run.ts",
    "trigger-eval": "tsx src/meta/trigger-eval.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
